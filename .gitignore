# ── ML Model files (large binaries – export from notebooks instead) ───────
# Comment out the next two lines if you WANT to commit the .pkl files
# backend/models/*.pkl
# backend/models/*.joblib

# Keep the .gitkeep so the models/ folder is tracked
!backend/models/.gitkeep

